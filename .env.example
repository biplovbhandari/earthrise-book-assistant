# Embedding
# EMBEDDING_PROVIDER options: local, remote
EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL_NAME options: BAAI/bge-large-en-v1.5 (CPU default), BAAI/bge-m3, Qwen3-Embedding-8B (GPU)
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
HF_HOME=/models

# Vector DB
# VECTOR_STORE_PROVIDER options: qdrant
VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=earthrise_book

# Retrieval
# RETRIEVAL_STRATEGY options: hybrid, parent_child
RETRIEVAL_STRATEGY=hybrid
# RERANKER_PROVIDER options: noop, local_cross_encoder
RERANKER_PROVIDER=noop

# LLM
# LLM_PROVIDER options: openai_compatible
LLM_PROVIDER=openai_compatible
# LLM_BASE_URL: NASA proxy (prod) or Ollama (local dev)
LLM_BASE_URL=https://proxy.fast.luna.nasa.gov/v1
LLM_API_KEY=
LLM_MODEL=

# Book
BOOK_HTML_DIR=_book

# App
# APP_ENV options: development, production, testing
APP_ENV=development
