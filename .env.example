# Embedding
# EMBEDDING_PROVIDER options: local
EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL_NAME options: BAAI/bge-large-en-v1.5 (CPU default), BAAI/bge-m3, Qwen3-Embedding-8B (GPU)
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
# HF_HOME: local dev uses .cache/models; Docker Compose mounts /models volume
HF_HOME=.cache/models

# Vector DB
# VECTOR_STORE_PROVIDER options: qdrant
VECTOR_STORE_PROVIDER=qdrant
# QDRANT_URL: set to http://localhost:6333 for local dev (uv run)
# Docker Compose overrides this to http://qdrant:6333 automatically
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=earthrise_book

# Retrieval
# RETRIEVAL_STRATEGY options: dense, hybrid
RETRIEVAL_STRATEGY=hybrid
RETRIEVAL_TOP_K=8
# RERANKER_PROVIDER options: noop, local_cross_encoder
RERANKER_PROVIDER=local_cross_encoder
# RERANKER_MODEL_NAME: cross-encoder model for local_cross_encoder provider
# Options: cross-encoder/ms-marco-MiniLM-L6-v2 (80MB, English, fast on CPU),
#          BAAI/bge-reranker-v2-m3 (2.3GB, multilingual, more accurate)
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L6-v2
# SPARSE_MODEL_NAME: fastembed sparse model for hybrid search
# Options: prithivida/Splade_PP_en_v1 (532MB, neural, term expansion),
#          Qdrant/bm25 (10MB, statistical, exact match, needs IDF modifier),
#          Qdrant/bm42-all-minilm-l6-v2-attentions (90MB, attention-based, needs IDF modifier)
SPARSE_MODEL_NAME=prithivida/Splade_PP_en_v1
# RRF_K: Reciprocal Rank Fusion constant (higher = more uniform weighting across ranks)
RRF_K=60

# LLM
# LLM_PROVIDER options: openai_compatible
LLM_PROVIDER=openai_compatible
# LLM_BASE_URL: where to reach the LLM
#   uv run (local dev):  http://localhost:11434/v1
#   Docker Compose:       http://host.docker.internal:11434/v1
#   NASA proxy (prod):    https://proxy.fast.luna.nasa.gov/v1
# NOTE: if running via Docker Compose with Ollama on the host, you MUST
# change this to host.docker.internal -- localhost inside the container
# points at the container itself, not the host.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:8b
# LLM_TIMEOUT_SECONDS: max wait for LLM response (default 60, min 1)
LLM_TIMEOUT_SECONDS=60

# Transcription
# WHISPER_MODEL options: large-v3 (best), medium, small, base, tiny
WHISPER_MODEL=large-v3

# Book
BOOK_HTML_DIR=_book
BOOK_SOURCE_DIR=book
BOOK_COMMIT_SHA=

# App
# APP_ENV options: development, production, testing
APP_ENV=development
