FROM python:3.12-slim

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project --group indexer

COPY src/ src/
COPY api/ api/
COPY scripts/ scripts/
RUN uv sync --frozen --no-dev --group indexer

ENV HF_HOME=/models
ENV PYTHONUNBUFFERED=1

CMD ["uv", "run", "python", "scripts/index_book.py"]
